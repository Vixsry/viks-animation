{
  "name": "viks-animation",
  "version": "1.1.4",
  "description": "A lightweight JavaScript animation library for smooth scroll-triggered animations",
  "main": "dist/viks.min.js",
  "style": "dist/viks.min.css",
  "scripts": {
    "dev": "webpack serve --config webpack.dev.js",
    "build": "webpack --config webpack.prod.js",
    "watch": "webpack --watch --config webpack.dev.js",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "format": "prettier --write \"src/**/*.{js,scss}\"",
    "test": "echo \"No tests specified\" && exit 0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Vixsry/viks-animation.git"
  },
  "keywords": [
    "animation",
    "scroll",
    "effects",
    "javascript",
    "css",
    "lightweight",
    "smooth",
    "transition"
  ],
  "author": "Vixsry",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/Vixsry/viks-animation/issues"
  },
  "homepage": "https://github.com/Vixsry/viks-animation#readme",
  "devDependencies": {
    "@babel/core": "^7.23.0",
    "@babel/preset-env": "^7.22.20",
    "babel-loader": "^9.1.3",
    "css-loader": "^6.8.1",
    "css-minimizer-webpack-plugin": "^5.0.1",
    "eslint": "^8.50.0",
    "mini-css-extract-plugin": "^2.7.6",
    "node-sass": "^9.0.0",
    "prettier": "^3.0.3",
    "sass-loader": "^13.3.2",
    "style-loader": "^3.3.3",
    "terser-webpack-plugin": "^5.3.9",
    "webpack": "^5.88.2",
    "webpack-cli": "^5.1.4",
    "webpack-dev-server": "^4.15.1",
    "webpack-merge": "^5.9.0"
  },
  "dependencies": {},
  "files": [
    "dist",
    "src",
    "LICENSE",
    "README.md"
  ],
  "engines": {
    "node": ">=14.0.0"
  },
  "browserslist": [
    "> 1%",
    "last 2 versions",
    "not dead"
  ],
  "ignore": [
    "**/.*",
    "node_modules",
    "bower_components",
    "test",
    "tests"
  ]
}
