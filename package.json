{
  "name": "viks-animation",
  "version": "1.1.4",
  "description": "Lightweight library for smooth scroll animations",
  "main": "dist/viks.min.js",
  "style": "dist/viks.min.css",
  "files": [
    "dist"
  ],
  "scripts": {
    "build:js": "rollup -c",
    "build:css": "postcss src/viks.css -o dist/viks.min.css",
    "watch:js": "rollup -c -w",
    "watch:css": "postcss src/viks.css -o dist/viks.min.css --watch",
    "test": "jest",
    "test:watch": "jest --watch",
    "lint": "eslint src/**/*.js",
    "lint:css": "stylelint src/**/*.css",
    "format": "prettier --write \"src/**/*.{js,css}\"",
    "build": "npm run lint && npm run lint:css && npm run build:js && npm run build:css",
    "prepare": "husky install",
    "dev": "concurrently \"npm run watch:js\" \"npm run watch:css\""
  },
  "keywords": [
    "animation",
    "scroll",
    "css",
    "javascript",
    "lightweight"
  ],
  "author": "Vixsry",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Vixsry/viks-animation.git"
  },
  "bugs": {
    "url": "https://github.com/Vixsry/viks-animation/issues"
  },
  "homepage": "https://github.com/Vixsry/viks-animation#readme",
  "devDependencies": {
    "@babel/core": "^7.23.6",
    "@babel/preset-env": "^7.23.6",
    "@rollup/plugin-babel": "^6.0.4",
    "@rollup/plugin-terser": "^0.4.4",
    "@testing-library/dom": "^9.3.3",
    "@testing-library/jest-dom": "^6.1.5",
    "autoprefixer": "^10.4.16",
    "concurrently": "^8.2.2",
    "cssnano": "^6.0.2",
    "eslint": "^8.56.0",
    "eslint-config-prettier": "^9.1.0",
    "husky": "^8.0.3",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "lint-staged": "^15.2.0",
    "postcss": "^8.4.32",
    "postcss-cli": "^11.0.0",
    "prettier": "^3.1.1",
    "rollup": "^4.9.1",
    "stylelint": "^16.1.0",
    "stylelint-config-standard": "^35.0.0"
  },
  "lint-staged": {
    "*.js": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.css": [
      "stylelint --fix",
      "prettier --write"
    ]
  }
}